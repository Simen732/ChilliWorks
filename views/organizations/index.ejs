<%- include('../partials/header') %>

<div class="container">
  <div class="row mt-4">
    <div class="col-md-12">
      <h1>Organizations</h1>
      <a href="/organizations/create" class="btn btn-primary mb-3">
        <i class="fas fa-plus"></i> Create New Organization
      </a>
      
      <% if (organizations && organizations.length > 0) { %>
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created By</th>
                    <th>Users</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% organizations.forEach(org => { %>
                    <tr>
                      <td><%= org.name %></td>
                      <td><%= org.description %></td>
                      <td><%= org.createdBy ? org.createdBy.name : 'Unknown' %></td>
                      <td><%= org.userCount || 0 %></td>
                      <td>
                        <a href="/organizations/<%= org._id %>" class="btn btn-info btn-sm">View</a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-info">
          No organizations found. Create your first organization.
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>