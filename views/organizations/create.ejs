<%- include('../partials/header') %>

<div class="container">
  <div class="row mt-4">
    <div class="col-md-8 m-auto">
      <div class="card">
        <div class="card-header">
          <h3>Create New Organization</h3>
        </div>
        <div class="card-body">
          <form action="/organizations" method="POST">
            <div class="form-group">
              <label for="name">Organization Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="form-control"
                placeholder="Enter organization name"
                required
              />
            </div>
            
            <div class="form-group">
              <label for="description">Description</label>
              <textarea
                id="description"
                name="description"
                class="form-control"
                rows="4"
                placeholder="Brief description of the organization"
              ></textarea>
            </div>
            
            <div class="form-group form-check">
              <input type="checkbox" class="form-check-input" id="allowUserRegistration" name="allowUserRegistration">
              <label class="form-check-label" for="allowUserRegistration">Allow user self-registration with code</label>
            </div>
            
            <div class="form-group">
              <button type="submit" class="btn btn-primary">Create Organization</button>
              <a href="/organizations" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>