<%- include('../partials/header') %>

<div class="container">
  <div class="row mt-4">
    <div class="col-md-8 m-auto">
      <div class="card">
        <div class="card-header">
          <h3>Create New Support Ticket</h3>
        </div>
        <div class="card-body">
          <!-- Validation error container will be inserted here -->
          <div id="description-validation-error"></div>
          
          <form action="/tickets" method="POST">
            <div class="form-group">
              <label for="title">Title</label>
              <input
                type="text"
                id="title"
                name="title"
                class="form-control"
                placeholder="Brief description of the issue"
                required
              />
            </div>
            
            <div class="form-group">
              <label for="category">Category</label>
              <select id="category" name="category" class="form-control" required>
                <option value="" disabled selected>Select a category</option>
                <option value="Hardware">Hardware</option>
                <option value="Software">Software</option>
                <option value="Network">Network</option>
                <option value="Other">Other</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="priority">Priority</label>
              <select id="priority" name="priority" class="form-control" required>
                <option value="Low">Low</option>
                <option value="Medium" selected>Medium</option>
                <option value="High">High</option>
                <option value="Urgent">Urgent</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="description">Description</label>
              <textarea
                id="description"
                name="description"
                class="form-control"
                rows="6"
                placeholder="Provide details about your issue (minimum 10 characters)"
                required
              ></textarea>
              <small class="form-text text-muted">Please provide at least 10 characters describing the issue</small>
            </div>
            
            <div class="form-group">
              <button type="submit" class="btn btn-primary">Submit Ticket</button>
              <a href="/dashboard" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    
    // Function to show styled validation error
    function showValidationError(message) {
      // Get the error container
      const errorContainer = document.getElementById('description-validation-error');
      
      // Create the alert element
      const alert = document.createElement('div');
      alert.className = 'alert alert-danger alert-dismissible fade show';
      alert.innerHTML = `
        ${message}
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      `;
      
      // Clear previous alerts and add the new one
      errorContainer.innerHTML = '';
      errorContainer.appendChild(alert);
      
      // Scroll to the alert
      alert.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Auto-dismiss after 5 seconds
      setTimeout(() => {
        $(alert).alert('close');
      }, 5000);
    }
    
    if (form) {
      form.addEventListener('submit', function(e) {
        const description = document.getElementById('description').value.trim();
        if (description.length < 10) {
          e.preventDefault();
          showValidationError('Description must be at least 10 characters long');
          document.getElementById('description').focus();
        }
      });
    }
  });
</script>

<%- include('../partials/footer') %>