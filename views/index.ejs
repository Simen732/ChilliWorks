<%- include('./partials/header') %>

<div class="container">
  <% if (!user) { %>
    <!-- Content for non-logged in users -->
    <div class="jumbotron text-center mt-5" style="background: linear-gradient(135deg, rgba(40, 49, 65, 0.9), rgba(45, 55, 72, 0.9)); border: 1px solid var(--primary-color); border-radius: 12px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(74, 111, 165, 0.2); padding: 3rem;">
      <h1 class="display-4" style="color: white; text-shadow: 0 0 10px rgba(74, 111, 165, 0.3);">Velkommen til ChilliWorks</h1>
      <p class="lead" style="color: rgba(233, 236, 239, 0.9);">Et moderne system for å håndtere støttehenvendelser</p>
      <hr class="my-4" style="background: linear-gradient(to right, var(--primary-color), var(--accent-purple)); height: 2px; border: none; opacity: 0.5;">
      <p style="color: rgba(233, 236, 239, 0.8);">Kom i gang ved å opprette en konto eller logge inn</p>
      <div class="mt-4">
        <a href="/auth/login" class="btn btn-primary btn-lg mr-3" style="padding: 0.8rem 2rem; border-radius: 50px; box-shadow: 0 4px 15px rgba(74, 111, 165, 0.3);">Logg inn</a>
        <a href="/auth/register" class="btn btn-secondary btn-lg" style="padding: 0.8rem 2rem; border-radius: 50px; background: linear-gradient(to right, var(--secondary-color), var(--info-color)); box-shadow: 0 4px 15px rgba(74, 111, 165, 0.3);">Registrer</a>
      </div>
    </div>
  <% } else { %>
    <!-- Content for logged in users -->
    <div class="jumbotron text-center mt-5" style="background: linear-gradient(135deg, rgba(40, 49, 65, 0.9), rgba(45, 55, 72, 0.9)); border: 1px solid var(--primary-color); border-radius: 12px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(74, 111, 165, 0.2); padding: 3rem;">
      <h1 class="display-4" style="color: white; text-shadow: 0 0 10px rgba(74, 111, 165, 0.3);">Velkommen tilbake, <%= user.name %>!</h1>
      <p class="lead" style="color: rgba(233, 236, 239, 0.9);">Takk for at du bruker ChilliWorks</p>
      <hr class="my-4" style="background: linear-gradient(to right, var(--primary-color), var(--accent-purple)); height: 2px; border: none; opacity: 0.5;">
      <div class="mt-4">
        <a href="/dashboard" class="btn btn-primary btn-lg mr-3" style="padding: 0.8rem 2rem; border-radius: 50px; box-shadow: 0 4px 15px rgba(74, 111, 165, 0.3);">Gå til Kontrollpanel</a>
        <a href="/tickets/create" class="btn btn-secondary btn-lg" style="padding: 0.8rem 2rem; border-radius: 50px; background: linear-gradient(to right, var(--secondary-color), var(--info-color)); box-shadow: 0 4px 15px rgba(74, 111, 165, 0.3);">Opprett Henvendelse</a>
      </div>
    </div>
  <% } %>
  
  <div class="row mt-5">
    <div class="col-md-4">
      <div class="card mb-4" style="transform: translateY(0); transition: transform 0.3s ease, box-shadow 0.3s ease;">
        <div class="card-body text-center">
          <i class="fas fa-ticket-alt fa-4x mb-3" style="background: linear-gradient(to right, var(--primary-color), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
          <h3>Opprett Henvendelser</h3>
          <p>Send inn støtteforespørsler med detaljer om ditt problem</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card mb-4" style="transform: translateY(0); transition: transform 0.3s ease, box-shadow 0.3s ease;">
        <div class="card-body text-center">
          <i class="fas fa-comments fa-4x mb-3" style="background: linear-gradient(to right, var(--primary-color), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
          <h3>Følg Fremdrift</h3>
          <p>Følg statusen på dine henvendelser og kommuniser med supportpersonell</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card mb-4" style="transform: translateY(0); transition: transform 0.3s ease, box-shadow 0.3s ease;">
        <div class="card-body text-center">
          <i class="fas fa-check-circle fa-4x mb-3" style="background: linear-gradient(to right, var(--primary-color), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
          <h3>Få Løsninger</h3>
          <p>Motta raske løsninger på dine tekniske problemer</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Add hover effect to cards
  document.addEventListener('DOMContentLoaded', function() {
    const cards = document.querySelectorAll('.card');
    cards.forEach(card => {
      card.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-10px)';
        this.style.boxShadow = '0 15px 30px rgba(0, 0, 0, 0.3), 0 0 15px rgba(52, 152, 219, 0.3)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0)';
        this.style.boxShadow = '0 4px 16px rgba(0, 0, 0, 0.2)';
      });
    });
  });
</script>

<%- include('./partials/footer') %>